# Copy to .env.local and fill in.
# .env.local is gitignored; .env.example is committed as the canonical list.

# --- Database ---------------------------------------------------------------
# Local Docker Postgres (see docker-compose.yml). For Neon in prod/preview,
# replace with the full postgres:// URL from the Vercel dashboard.
DATABASE_URL=postgres://spaceforge:spaceforge@localhost:5432/spaceforge

# --- Object storage ---------------------------------------------------------
# fs     → FsBlobDriver: writes to .spaceforge-local/blob/ (local dev, no network)
# vercel → VercelBlobDriver: real Vercel Blob (preview + production)
BLOB_DRIVER=fs

# Required when BLOB_DRIVER=vercel. Provision a token in the Vercel dashboard
# under Storage → Blob → Connect.
BLOB_READ_WRITE_TOKEN=

# --- Auth (Clerk) -----------------------------------------------------------
# Get from https://dashboard.clerk.com — use the "Development" instance keys
# locally. Dev keys accept localhost callbacks out of the box.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# --- Photo proxy ------------------------------------------------------------
# https://unsplash.com/oauth/applications — grab the "Access Key". Stays
# server-side so it never appears in the client bundle.
UNSPLASH_ACCESS_KEY=
